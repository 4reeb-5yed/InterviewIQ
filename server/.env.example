# InterviewIQ backend environment template.
# Copy to .env and fill in real values. Never commit a populated .env.

# --- Server ---
PORT=8000
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=http://localhost:5173

# --- AI provider (provider-agnostic) ---
# AI_PROVIDER: anthropic | openai | gemini | bedrock
#   aliases -> OpenAI-compatible client: openrouter | local | openai_compatible
# Set AI_API_KEY to the credential for the selected provider.
# Per-agent model ids (below) must match the chosen provider.
# See docs/AI_PROVIDERS.md for full details and examples.
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-your-key-here

# OpenAI-compatible endpoints (OpenRouter / Ollama / vLLM / LM Studio / Together).
# Example local Ollama: AI_PROVIDER=local, AI_BASE_URL=http://localhost:11434/v1,
#                       AI_API_KEY=ollama, *_AGENT_MODEL=llama3.1
# AI_BASE_URL=
# AI_ORGANIZATION=

# AWS Bedrock (AI_PROVIDER=bedrock). Region is required; credentials may come
# from these vars or the default AWS credential chain (profile / instance role).
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Per-agent model identifiers (must match the selected provider) ---
# Anthropic : claude-3-5-sonnet-latest
# OpenAI    : gpt-4o-mini
# Gemini    : gemini-1.5-pro
# Bedrock   : anthropic.claude-3-5-sonnet-20240620-v1:0  (or any Converse model id)
# OpenRouter: openai/gpt-4o-mini  (etc.)
# Local     : llama3.1  (whatever your endpoint serves)
RESUME_AGENT_MODEL=claude-3-5-sonnet-latest
JOB_AGENT_MODEL=claude-3-5-sonnet-latest
CAREER_AGENT_MODEL=claude-3-5-sonnet-latest
SKILL_GAP_AGENT_MODEL=claude-3-5-sonnet-latest
QUESTION_AGENT_MODEL=claude-3-5-sonnet-latest

# --- Database (async driver) ---
DATABASE_URL=postgresql+asyncpg://interviewiq:interviewiq@localhost:5432/interviewiq

# --- Uploads ---
MAX_FILE_SIZE_MB=5

# --- Rate limiting ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30

# --- Cache ---
CACHE_ANALYSIS_TTL_SECONDS=86400

# --- OPTIONAL: Redis ---
# Leave unset for the MVP to use the in-memory cache/task implementations.
# REDIS_URL=redis://localhost:6379/0

# --- Feature flags (all disabled for Phase 1) ---
ENABLE_RAG=false
ENABLE_MEMORY=false
ENABLE_COMPANY_INTELLIGENCE=false
